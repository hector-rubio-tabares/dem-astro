{
  "name": "portfolio-mfe-pilot",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:hot",
    "dev:hot": "concurrently -n SHELL,REACT,ANGULAR -c cyan,green,yellow \"pnpm dev:shell\" \"pnpm dev:react\" \"pnpm dev:angular\"",
    "dev:shell": "pnpm --filter portfolio-shell-astro dev",
    "dev:react": "pnpm --filter portfolio-react-mf dev",
    "dev:angular": "pnpm --filter portfolio-angular-mf start:mf",
    "build": "pnpm build:all",
    "build:all": "pnpm build:react && pnpm build:angular && pnpm build:shell",
    "build:shell": "pnpm --filter portfolio-shell-astro build",
    "build:react": "pnpm --filter portfolio-react-mf build",
    "build:angular": "pnpm --filter portfolio-angular-mf build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^2.1.9",
    "concurrently": "^9.2.1",
    "vitest": "^2.1.9"
  }
}
