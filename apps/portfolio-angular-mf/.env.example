# ════════════════════════════════════════════════════════════════════
# Angular MFE — Referencia de configuración
# ════════════════════════════════════════════════════════════════════
#
# ⚠️ Angular NO lee .env por defecto. Este archivo es solo REFERENCIA.
#    Los valores reales están en:
#      src/environments/environment.ts       (desarrollo)
#      src/environments/environment.prod.ts  (producción)
#
# Topología de puertos del sistema:
#   Shell   → puerto 4321  → referenciado en environment.ts (allowedShellOrigins)
#   React   → puerto 5173  (no referenciado aquí)
#   Angular → puerto 4201  → este MFE (fijado en package.json start:mf --port 4201)
#
# El shell carga este MFE desde: http://127.0.0.1:4201/main.js
#   → declarado en shell/.env como PUBLIC_ANGULAR_MF_URL
# ════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────
# DESARROLLO - Dev Server
# ────────────────────────────────────────────────────────────────────

# Puerto del dev server
PORT=4201

# ────────────────────────────────────────────────────────────────────
# API - Backend
# ────────────────────────────────────────────────────────────────────

# URL base de API (desarrollo)
API_BASE_URL=http://localhost:8080

# Timeout de requests HTTP (ms)
API_TIMEOUT_MS=10000

# ────────────────────────────────────────────────────────────────────
# SEGURIDAD - CORS
# ────────────────────────────────────────────────────────────────────

# Orígenes del Shell permitidos (whitelist CSV)
ALLOWED_SHELL_ORIGINS=http://127.0.0.1:4321,http://localhost:4321

# ────────────────────────────────────────────────────────────────────
# OBSERVABILIDAD
# ────────────────────────────────────────────────────────────────────

# Sentry DSN (Error Tracking)
SENTRY_DSN=

# Environment name
ENV_NAME=development

# ────────────────────────────────────────────────────────────────────
# DEBUGGING
# ────────────────────────────────────────────────────────────────────

# Nivel de logs (debug, info, warn, error)
LOG_LEVEL=debug

# Habilitar Angular DevTools (solo desarrollo)
ENABLE_DEVTOOLS=true
