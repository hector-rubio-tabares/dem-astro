# ════════════════════════════════════════════════════════════════════
# React MFE — Plantilla de configuración
# ════════════════════════════════════════════════════════════════════
#
# Topología de puertos del sistema:
#   Shell   → puerto 4321  → referenciado en VITE_ALLOWED_SHELL_ORIGINS (CORS)
#   React   → puerto 5173  → este MFE (configurable en VITE_MF_PORT)
#   Angular → puerto 4201  (no referenciado aquí)
#
# El shell carga este MFE desde: http://VITE_MF_HOST:VITE_MF_PORT/src/mf-entry.tsx
#   → declarado en shell/.env como PUBLIC_REACT_MF_URL
#
# Todas las variables requieren prefijo VITE_ para ser accesibles desde el cliente.
# .env.development — incluido con valores por defecto para desarrollo local
# .env.production  — crear con host/port del servidor de producción
# ════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────
# DESARROLLO - Dev Server
# ────────────────────────────────────────────────────────────────────

# Host/Puerto para desarrollo local
VITE_MF_HOST=127.0.0.1
VITE_MF_PORT=5173

# ────────────────────────────────────────────────────────────────────
# SEGURIDAD - CORS
# ────────────────────────────────────────────────────────────────────

# Orígenes del Shell permitidos (whitelist CSV)
VITE_ALLOWED_SHELL_ORIGINS=http://127.0.0.1:4321,http://localhost:4321

# ────────────────────────────────────────────────────────────────────
# API - Backend
# ────────────────────────────────────────────────────────────────────

# URL base de API (desarrollo)
VITE_API_BASE_URL=http://localhost:8080

# Timeout de requests HTTP (ms)
VITE_API_TIMEOUT_MS=10000

# ────────────────────────────────────────────────────────────────────
# OBSERVABILIDAD
# ────────────────────────────────────────────────────────────────────

# Sentry DSN (Error Tracking)
VITE_SENTRY_DSN=

# Environment name
VITE_ENV_NAME=development

# ────────────────────────────────────────────────────────────────────
# DEBUGGING
# ────────────────────────────────────────────────────────────────────

# Nivel de logs (debug, info, warn, error)
VITE_LOG_LEVEL=debug

# Habilitar React DevTools (solo desarrollo)
VITE_ENABLE_DEVTOOLS=true
