---
/**
 * Página Projects
 * Showcase de proyectos con integración de MFEs
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Proyectos - Portfolio MFE"
  description="Explora los proyectos construidos con micro-frontends"
  loadsMFEs={true}
>
  <div class="container">
    <!-- Page Header -->
    <section class="page-header">
      <h1>Proyectos</h1>
      <p class="lead">
        Cada proyecto demuestra diferentes patrones y capacidades de la arquitectura MFE.
      </p>
    </section>

    <!-- Projects Grid -->
    <section class="projects-grid">
      <article class="project-card">
        <div class="project-header">
          <h3>Sistema de Comunicación Inter-MFE</h3>
          <span class="mfe-badge react">React</span>
          <span class="mfe-badge angular">Angular</span>
        </div>
        <p>
          Demostración de EventBus tipado y BroadcastChannel para comunicación 
          mismo-tab y multi-tab entre micro-frontends.
        </p>
        <div class="project-demo">
          <div class="mf-slot react" data-mf="react">
            <div class="mfe-loading"></div>
          </div>
        </div>
      </article>

      <article class="project-card">
        <div class="project-header">
          <h3>Web Components con Angular</h3>
          <span class="mfe-badge angular">Angular</span>
        </div>
        <p>
          Integración de Angular 21 como Web Component usando Custom Elements,
          con Signals y detección de cambios zoneless.
        </p>
        <div class="project-demo">
          <div class="mf-slot angular" data-mf="angular">
            <div class="mfe-loading"></div>
          </div>
        </div>
      </article>

      <article class="project-card">
        <div class="project-header">
          <h3>Sistema de Diseño Compartido</h3>
          <span class="mfe-badge">CSS</span>
        </div>
        <p>
          Tokens CSS, temas claro/oscuro y componentes reutilizables 
          compartidos entre Astro, React y Angular.
        </p>
        <div class="design-system-demo">
          <div class="flex gap-4">
            <button class="btn-primary">Primario</button>
            <button class="btn-secondary">Secundario</button>
          </div>
          <div class="flex gap-4 mt-4">
            <div class="card success">✓ Success</div>
            <div class="card warning">⚠ Warning</div>
            <div class="card error">✗ Error</div>
          </div>
        </div>
      </article>
    </section>

    <!-- Technical Stack -->
    <section class="tech-stack">
      <h2>Stack Técnico</h2>
      <div class="tech-grid">
        <div class="tech-item">
          <h4>Shell</h4>
          <p>Astro 6.0</p>
          <p class="tech-detail">Orquestación y SSG</p>
        </div>
        <div class="tech-item">
          <h4>React MFE</h4>
          <p>React 19 + Vite</p>
          <p class="tech-detail">Function-based mount</p>
        </div>
        <div class="tech-item">
          <h4>Angular MFE</h4>
          <p>Angular 21</p>
          <p class="tech-detail">Web Components</p>
        </div>
        <div class="tech-item">
          <h4>Shared Library</h4>
          <p>@mf/shared</p>
          <p class="tech-detail">EventBus + Validadores</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* ========== PAGE HEADER ========== */
  .page-header {
    text-align: center;
    padding: var(--spacing-12) 0 var(--spacing-8);
    border-bottom: var(--border-width-thin) solid var(--color-border-secondary);
    margin-bottom: var(--spacing-12);
  }

  .lead {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
    max-width: 700px;
    margin: 0 auto;
  }

  /* ========== PROJECTS GRID ========== */
  .projects-grid {
    display: grid;
    gap: var(--spacing-8);
    margin-bottom: var(--spacing-16);
  }

  .project-card {
    background-color: var(--color-card-bg);
    border: var(--border-width-thin) solid var(--color-card-border);
    border-radius: var(--border-radius-xl);
    padding: var(--spacing-6);
    box-shadow: var(--shadow-lg);
    transition: all var(--transition-base);
  }

  .project-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
  }

  .project-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    margin-bottom: var(--spacing-4);
    flex-wrap: wrap;
  }

  .project-header h3 {
    margin: 0;
    flex: 1;
    min-width: 200px;
  }

  .project-demo {
    margin-top: var(--spacing-6);
    padding: var(--spacing-4);
    background-color: var(--color-bg-secondary);
    border-radius: var(--border-radius-lg);
  }

  .design-system-demo {
    margin-top: var(--spacing-6);
    padding: var(--spacing-6);
    background-color: var(--color-bg-secondary);
    border-radius: var(--border-radius-lg);
  }

  /* ========== TECH STACK ========== */
  .tech-stack {
    padding: var(--spacing-12) 0;
    text-align: center;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-6);
    margin-top: var(--spacing-8);
  }

  .tech-item {
    padding: var(--spacing-6);
    background-color: var(--color-bg-secondary);
    border-radius: var(--border-radius-lg);
    border: var(--border-width-thin) solid var(--color-border-secondary);
  }

  .tech-item h4 {
    margin-bottom: var(--spacing-2);
    color: var(--color-primary-600);
  }

  [data-theme="dark"] .tech-item h4 {
    color: var(--color-primary-400);
  }

  .tech-item p {
    margin-bottom: var(--spacing-1);
    font-weight: var(--font-weight-semibold);
  }

  .tech-detail {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    margin-bottom: 0;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 768px) {
    .page-header {
      padding: var(--spacing-8) 0 var(--spacing-6);
      margin-bottom: var(--spacing-8);
    }

    .lead {
      font-size: var(--font-size-lg);
    }

    .projects-grid {
      gap: var(--spacing-6);
    }

    .tech-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { initializeMicrofrontendsHexagonal } from '../scripts/mf-init-hexagonal';

  document.addEventListener('DOMContentLoaded', () => {
    initializeMicrofrontendsHexagonal()
      .then(() => {
        console.log('[Projects] ✅ MFEs inicializados con arquitectura hexagonal');
      })
      .catch((error) => {
        console.error('[Projects] ❌ Error inicializando MFEs:', error);
      });
  });
</script>
