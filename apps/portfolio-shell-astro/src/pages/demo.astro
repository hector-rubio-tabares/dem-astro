---
import demoScriptUrl from '../scripts/demo-hot.ts?url'; // Script universal (dev + prod)
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Demo Integracion Micro-Frontends</title>
    <style>
      :root {
        --shell-bg: radial-gradient(circle at 15% 0%, #e8f4ff 0, #f8fbff 40%, #fcfcfd 100%);
        --shell-card: #ffffff;
        --shell-text: #112031;
        --shell-subtle: #4a6178;
        --shell-border: #dbe5ee;
        --react-accent: #14b8ff;
        --react-soft: #e9f8ff;
        --angular-accent: #ff8c2a;
        --angular-soft: #fff3e6;
        font-family: "Segoe UI", sans-serif;
        color: var(--shell-text);
      }

      body {
        margin: 0;
        background: var(--shell-bg);
      }

      main {
        max-width: 980px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      h1 {
        margin: 0;
        font-size: clamp(1.6rem, 3vw, 2.3rem);
      }

      .intro {
        margin: 0.35rem 0 0;
        color: var(--shell-subtle);
      }

      .pill {
        display: inline-block;
        margin-bottom: 0.75rem;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        border: 1px solid #c8d9ea;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #31577a;
        background: #f2f8ff;
      }

      .grid {
        margin-top: 1.25rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1rem;
      }

      .slot {
        border: 1px solid var(--shell-border);
        border-radius: 14px;
        background: var(--shell-card);
        padding: 1rem;
        min-height: 160px;
        box-shadow: 0 10px 25px rgba(20, 33, 61, 0.08);
      }

      .slot h2 {
        margin-top: 0;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .slot.react {
        border-top: 4px solid var(--react-accent);
        background: linear-gradient(180deg, var(--react-soft) 0%, #ffffff 22%);
      }

      .slot.angular {
        border-top: 4px solid var(--angular-accent);
        background: linear-gradient(180deg, var(--angular-soft) 0%, #ffffff 22%);
      }

      .error {
        color: #a30000;
      }
    </style>
  </head>
  <body>
    <main>
      <span class="pill">Astro Shell</span>
      <h1>Demo local: Angular + React en la misma vista</h1>
      <p class="intro">Ambos micro-frontends se montan en runtime desde el shell Astro.</p>

      <div class="grid">
        <section class="slot react">
          <h2>React MF</h2>
          <div id="react-slot"></div>
        </section>

        <section class="slot angular">
          <h2>Angular MF</h2>
          <div id="angular-slot"></div>
        </section>
      </div>
    </main>

    <script type="module" src={demoScriptUrl}></script>
  </body>
</html>
