---
import demoHotScriptUrl from '../scripts/demo-hot.ts?url';

const reactPortLabel = import.meta.env.PUBLIC_REACT_MF_DEV_URL ?? 'http://127.0.0.1:5173';
const angularPortLabel = import.meta.env.PUBLIC_ANGULAR_MF_DEV_URL ?? 'http://127.0.0.1:4201';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Demo Hot - Angular + React</title>
    <style>
      :root {
        --shell-bg: radial-gradient(circle at 15% 0%, #e8f4ff 0, #f8fbff 40%, #fcfcfd 100%);
        --shell-card: #ffffff;
        --shell-text: #112031;
        --shell-subtle: #4a6178;
        --shell-border: #dbe5ee;
        --react-accent: #14b8ff;
        --react-soft: #e9f8ff;
        --angular-accent: #ff8c2a;
        --angular-soft: #fff3e6;
        font-family: "Segoe UI", sans-serif;
        color: var(--shell-text);
      }

      body {
        margin: 0;
        background: var(--shell-bg);
      }

      main {
        max-width: 980px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      h1 {
        margin: 0;
        font-size: clamp(1.6rem, 3vw, 2.3rem);
      }

      .intro {
        margin: 0.35rem 0 0;
        color: var(--shell-subtle);
      }

      .pill {
        display: inline-block;
        margin-bottom: 0.75rem;
        padding: 0.3rem 0.7rem;
        border-radius: 999px;
        border: 1px solid #c8d9ea;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #31577a;
        background: #f2f8ff;
      }

      .grid {
        margin-top: 1.25rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
      }

      .slot {
        border: 1px solid var(--shell-border);
        border-radius: 14px;
        background: var(--shell-card);
        padding: 1rem;
        min-height: 180px;
        box-shadow: 0 10px 25px rgba(20, 33, 61, 0.08);
      }

      .slot h2 {
        margin-top: 0;
        font-size: 0.95rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .slot.react {
        border-top: 4px solid var(--react-accent);
        background: linear-gradient(180deg, var(--react-soft) 0%, #ffffff 22%);
      }

      .slot.angular {
        border-top: 4px solid var(--angular-accent);
        background: linear-gradient(180deg, var(--angular-soft) 0%, #ffffff 22%);
      }

      .slot.astro {
        border-top: 4px solid #7f5af0;
        background: linear-gradient(180deg, #f3f0ff 0%, #ffffff 22%);
      }

      .astro-controls h3 {
        margin: 0 0 0.5rem;
        font-size: 1.05rem;
        color: #5a3d9c;
      }

      .astro-controls p {
        margin: 0 0 0.7rem;
        color: #7a6199;
        font-size: 0.9rem;
      }

      .astro-btn {
        border: 1px solid #7f5af0;
        background: #ffffff;
        color: #5a3d9c;
        border-radius: 8px;
        padding: 0.45rem 0.75rem;
        font-weight: 600;
        cursor: pointer;
      }

      .astro-btn:hover {
        background: #f3f0ff;
      }

      .astro-btn-secondary {
        border: 1px solid #7f5af0;
        background: #f7f4ff;
        color: #5a3d9c;
        border-radius: 8px;
        padding: 0.35rem 0.6rem;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
      }

      .astro-btn-secondary:hover {
        background: #ebe4ff;
      }

      .event-controls {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.7rem;
        flex-wrap: wrap;
      }

      .messages-log {
        margin-top: 1rem;
        padding: 0.7rem;
        border-radius: 8px;
        background: #f7f4ff;
        border: 1px dashed #c2b0ff;
      }

      .messages-log h4 {
        margin: 0 0 0.5rem;
        font-size: 0.85rem;
        color: #5a3d9c;
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }

      .messages-log ul {
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .messages-log li {
        font-size: 0.8rem;
        color: #7a6199;
        padding: 0.25rem 0;
        border-bottom: 1px solid #ebe4ff;
      }

      .messages-log li:last-child {
        border-bottom: none;
      }

      .messages-log strong {
        color: #5a3d9c;
        text-transform: uppercase;
        font-size: 0.75rem;
      }

      .messages-log em {
        font-style: normal;
        font-weight: 600;
      }

      .messages-log em.react {
        color: #14b8ff;
      }

      .messages-log em.angular {
        color: #ff8c2a;
      }

      .meta {
        margin-top: 1rem;
        color: var(--shell-subtle);
        font-size: 0.95rem;
      }

      .health {
        margin-top: 1rem;
        padding: 0.9rem 1rem;
        border: 1px solid var(--shell-border);
        border-radius: 12px;
        background: #ffffff;
      }

      .health h3 {
        margin: 0 0 0.65rem;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .health p {
        margin: 0.35rem 0;
        color: var(--shell-subtle);
      }

      .status-badge {
        display: inline-block;
        margin-left: 0.5rem;
        padding: 0.08rem 0.45rem;
        border-radius: 999px;
        font-size: 0.75rem;
        border: 1px solid #cfdbe7;
        background: #f6fbff;
      }

      .bus-panel {
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 12px;
        border: 1px solid var(--shell-border);
        background: #ffffff;
      }

      .bus-panel h3 {
        margin: 0 0 0.7rem;
        font-size: 0.9rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .controls-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.7rem;
      }

      .controls-grid label {
        display: block;
        font-size: 0.82rem;
        color: var(--shell-subtle);
        margin-bottom: 0.25rem;
      }

      .controls-grid select,
      .controls-actions button {
        width: 100%;
        border: 1px solid #c6d7e7;
        border-radius: 8px;
        background: #ffffff;
        color: #17324a;
        padding: 0.45rem 0.55rem;
      }

      .controls-actions {
        margin-top: 0.7rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.7rem;
      }

      .controls-actions button {
        cursor: pointer;
        font-weight: 600;
      }

      .state-output {
        margin-top: 0.7rem;
        padding: 0.55rem 0.65rem;
        border-radius: 8px;
        background: #f7fbff;
        border: 1px dashed #bed3e6;
        color: #294d6b;
        font-size: 0.85rem;
      }

      :root[data-demo-theme='ocean'] body {
        background: radial-gradient(circle at 15% 0%, #dcf6ff 0, #eefcff 42%, #fbffff 100%);
      }

      :root[data-demo-theme='sunset'] body {
        background: radial-gradient(circle at 15% 0%, #fff0df 0, #fff7ef 42%, #fffdf9 100%);
      }

      .ok {
        color: #056b17;
      }

      .error {
        color: #a30000;
      }
    </style>
  </head>
  <body>
    <main>
      <span class="pill">Astro Shell</span>
      <h1>Demo HOT: Angular + React en la misma vista</h1>
      <p class="intro">Sin build manual: el shell carga ambos MFs desde sus dev servers.</p>

      <div class="grid">
        <section class="slot react">
          <h2>React MF ({reactPortLabel})</h2>
          <div id="react-slot"></div>
        </section>

        <section class="slot angular">
          <h2>Angular MF ({angularPortLabel})</h2>
          <div id="angular-slot"></div>
        </section>

        <section class="slot astro">
          <h2>Astro Shell</h2>
          <div class="astro-controls">
            <h3>Astro puede comunicarse también</h3>
            <p>Contador local: <strong id="astro-clicks">0</strong></p>
            <button class="astro-btn" type="button" id="astro-increment">
              Incrementar en Astro
            </button>
            
            <div class="event-controls">
              <button class="astro-btn-secondary" type="button" id="astro-send-tab">
                📤 Enviar a Tab (EventBus)
              </button>
              <button class="astro-btn-secondary" type="button" id="astro-send-multitab">
                🌐 Multi-tab (BroadcastChannel)
              </button>
            </div>

            <div class="messages-log" id="astro-messages" style="display: none;">
              <h4>Mensajes recibidos:</h4>
              <ul id="astro-messages-list"></ul>
            </div>
          </div>
        </section>
      </div>

      <section class="health">
        <h3>Estado de Endpoints HOT</h3>
        <p id="react-endpoint">React: {reactPortLabel} <span class="status-badge" id="react-health">pendiente</span></p>
        <p id="angular-endpoint">Angular: {angularPortLabel} <span class="status-badge" id="angular-health">pendiente</span></p>
      </section>

      <p class="meta" id="status"></p>
    </main>

    <script type="module" src={demoHotScriptUrl}></script>
  </body>
</html>
