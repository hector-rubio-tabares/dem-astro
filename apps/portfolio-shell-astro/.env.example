# ════════════════════════════════════════════════════════════════════
# Shell Astro — Plantilla de configuración
# ════════════════════════════════════════════════════════════════════
#
# Topología de puertos del sistema:
#   Shell   → puerto 4321  (este servidor, referenciado en ALLOWED_SHELL_ORIGINS de los MFEs)
#   React   → puerto 5173  → PUBLIC_REACT_MF_URL  (configurable en react/.env VITE_MF_PORT)
#   Angular → puerto 4201  → PUBLIC_ANGULAR_MF_URL (en angular/package.json start:mf)
#
# .env.development — incluido con valores por defecto para desarrollo local
# .env.production  — crear con URLs reales de cada MFE antes de pnpm build
# .env             — local, NO versionado, sobrescribe cualquier otra variable
# ════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────
# MICROFRONTENDS - URLs de Carga
# ────────────────────────────────────────────────────────────────────

# URL completa del módulo de entrada de cada MFE.
# Cambia el valor en .env.development / .env.production / .env según el entorno.
# El código nunca distingue dev de prod: solo lee esta variable.
PUBLIC_REACT_MF_URL=http://127.0.0.1:5173/src/mf-entry.tsx
PUBLIC_ANGULAR_MF_URL=http://127.0.0.1:4201/main.js

# ────────────────────────────────────────────────────────────────────
# SEGURIDAD - Module Federation
# ────────────────────────────────────────────────────────────────────

# Orígenes permitidos (whitelist CSV)
PUBLIC_ALLOWED_REMOTE_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:4201,http://localhost:5173,http://localhost:4201

PUBLIC_MF_MODULE_TIMEOUT_MS=8000

PUBLIC_API_BASE_URL=http://localhost:8080

# ────────────────────────────────────────────────────────────────────
# AUTENTICACIÓN (Demo)
# ────────────────────────────────────────────────────────────────────

# Las credenciales demo NO llevan prefijo PUBLIC_ (no se exponen al cliente)
DEMO_AUTH_ENABLED=true
DEMO_USERNAME=admin
DEMO_PASSWORD=admin123

# JWT Secret: solo en .env local (nunca commiteado). En prod: openssl rand -base64 32
# JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET

# ────────────────────────────────────────────────────────────────────
# OBSERVABILIDAD
# ────────────────────────────────────────────────────────────────────

# Sentry (Error Tracking)
PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Google Analytics
PUBLIC_GA_MEASUREMENT_ID=

# ────────────────────────────────────────────────────────────────────
# DEBUGGING
# ────────────────────────────────────────────────────────────────────

# Nivel de logs (debug, info, warn, error)
PUBLIC_LOG_LEVEL=info

# Modo debug (deshabilitar en producción)
PUBLIC_DEBUG_MODE=false
