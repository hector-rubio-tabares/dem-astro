# ════════════════════════════════════════════════════════════════════
# Shell Astro - Configuración de Microfrontends
# ════════════════════════════════════════════════════════════════════
# 
# IMPORTANTE: Este archivo es una plantilla.
# Para desarrollo: copia este archivo a .env.development
# Para producción: copia este archivo a .env.production y configura URLs reales
# 
# Los archivos .env.development y .env.production se versionan en Git.
# El archivo .env (local) NO se versiona y sobrescribe las variables.
# ════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────
# MICROFRONTENDS - URLs de Carga
# ────────────────────────────────────────────────────────────────────

# URLs de desarrollo (dev servers con HMR)
PUBLIC_REACT_MF_DEV_URL=http://127.0.0.1:5173
PUBLIC_ANGULAR_MF_DEV_URL=http://127.0.0.1:4201

# URLs de producción (CDN o servidor)
# OBLIGATORIO: Configurar antes de `pnpm build`
PUBLIC_REACT_MF_PROD_URL=https://mf-react.tudominio.com
PUBLIC_ANGULAR_MF_PROD_URL=https://mf-angular.tudominio.com

# ────────────────────────────────────────────────────────────────────
# SEGURIDAD - Module Federation
# ────────────────────────────────────────────────────────────────────

# Orígenes permitidos (whitelist CSV)
PUBLIC_ALLOWED_REMOTE_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:4201,http://localhost:5173,http://localhost:4201

# Timeout de carga de módulos remotos (ms)
PUBLIC_MF_MODULE_TIMEOUT_MS=8000

# ────────────────────────────────────────────────────────────────────
# AUTENTICACIÓN (Demo)
# ────────────────────────────────────────────────────────────────────

# Habilitar auth demo (DESACTIVAR en producción)
PUBLIC_DEMO_AUTH_ENABLED=true

# Credenciales demo (solo desarrollo)
PUBLIC_DEMO_USERNAME=admin
PUBLIC_DEMO_PASSWORD=admin123

# JWT Secret (producción: generar con `openssl rand -base64 32`)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_SECRET

# ────────────────────────────────────────────────────────────────────
# OBSERVABILIDAD
# ────────────────────────────────────────────────────────────────────

# Sentry (Error Tracking)
PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Google Analytics
PUBLIC_GA_MEASUREMENT_ID=

# ────────────────────────────────────────────────────────────────────
# DEBUGGING
# ────────────────────────────────────────────────────────────────────

# Nivel de logs (debug, info, warn, error)
PUBLIC_LOG_LEVEL=info

# Modo debug (deshabilitar en producción)
PUBLIC_DEBUG_MODE=false
